# Homer 需要把这个文件复制到 ~/.morningreader/nas.env 并填实际值
# 不要把真实凭据写进 nas.env 后 commit 进 git！.gitignore 已防护，但仍要小心
NAS_SERVER=192.168.50.167      # 改成你的 NAS IP 或 hostname（任务 A1 输出确认）
NAS_SHARE=share                # SMB share 名
NAS_USER=shareUser             # SMB 用户名
MOUNT_POINT=/Volumes/share     # 本地挂载点（保持默认）
