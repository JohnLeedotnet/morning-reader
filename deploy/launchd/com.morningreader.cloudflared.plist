<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.morningreader.cloudflared</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-c</string>
    <string>source $HOME/.morningreader/cloudflared.env &amp;&amp; exec /opt/homebrew/bin/cloudflared tunnel run --protocol http2 --token "$CLOUDFLARED_TOKEN"</string>
  </array>
  <key>KeepAlive</key>
  <true/>
  <key>ThrottleInterval</key>
  <integer>30</integer>
  <key>RunAtLoad</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/tmp/morningreader-cloudflared.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/morningreader-cloudflared.err.log</string>
</dict>
</plist>
